#!/bin/bash
set -e

if [ ! -f status.cfg ]; then
  echo "No config found"
  exit 0
fi

curlrc=$(mktemp)
log=$(mktemp)

cat > "$curlrc" << EOF
--retry 5
--retry-delay 5
--retry-all-errors
--fail
--parallel
--silent
--output /dev/null
--expand-write-out "%output{>>{{log}}}{{id}},{{date}},%{http_code}\n"
EOF

curl_args=()
url_count=0
while IFS= read -r line || [[ -n $line ]]; do
  if [[ -z $line || $line == \#* ]]; then continue; fi
  read -r id url rest <<< "$line"
  if [[ -z $id || -z $url ]]; then continue; fi
  url_count=$((url_count + 1))
  if [[ ${#curl_args[@]} -gt 0 ]]; then curl_args+=("--next"); fi
  curl_args+=("--variable" "log=${log}" "--variable" "id=${id}" "--config" "$curlrc" "$url")

  # eval needed to properly parse curl arguments with quotes (JSON data)
  if [[ -n $rest ]]; then eval "curl_args+=($rest)"; fi
done < status.cfg

if git ls-remote --exit-code --heads origin log > /dev/null; then
  git fetch origin log:log

  # drop old commits to prevent log branch from growing indefinitely
  first_new=$(git log log --format="%H" --after="2 months ago" | tail -1)
  if [[ -n $first_new ]] && git rev-parse --verify "${first_new}^" > /dev/null 2>&1; then
    echo "Squashing commits older than 2 months..."
    squash_root=$(git commit-tree "${first_new}^{tree}" -m "Squashed old commits")
    git rebase --onto "$squash_root" "${first_new}^" log
  elif [[ -z $first_new ]]; then
    # all commits are older than the cutoff — squash the entire branch into one commit
    echo "All commits are older than 2 months, squashing entire history..."
    squash_root=$(git commit-tree "log^{tree}" -m "Squashed old commits")
    git branch -f log "$squash_root"
  fi
  git switch log
else
  git switch --orphan log
fi

curl_exit_code=0
if [[ ${#curl_args[@]} -gt 0 ]]; then
  curl --variable date="$(date '+%Y-%m-%d %H:%M:%S')" "${curl_args[@]}" || curl_exit_code=$?
fi

# display output in action log and append to global log
echo "Check details:"
cat "$log" | tee -a log.csv
echo ""

if [[ $url_count -gt 0 && -f log.csv ]]; then
  lines_to_keep=$((url_count * 8640))
  tail -n "$lines_to_keep" log.csv > log.csv.tmp && mv log.csv.tmp log.csv
fi

# Clean up temporary file
rm "$curlrc"
rm "$log"

exit $curl_exit_code
